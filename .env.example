DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Webhook security
REQUIRE_WEBHOOK_SIGNATURE=true
TRADE_WEBHOOK_SECRET_CURRENT=change_me_current_secret
TRADE_WEBHOOK_SECRET_PREVIOUS=

# UI
NEXT_PUBLIC_APP_NAME=Trade Optimizer

# TradeSystem outbound example
OPTIMIZER_WEBHOOK_URL=http://localhost:3000/api/webhooks/tradesystem
OPTIMIZER_WEBHOOK_SECRET=change_me_current_secret
OPTIMIZER_WEBHOOK_ENABLED=true