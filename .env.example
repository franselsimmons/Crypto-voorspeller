# ================= DATABASE =================
# Neon / Supabase / Vercel Postgres URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ================= WEBHOOK SECURITY =================
# Zet exact dezelfde secret in je TradeSystem webhook sender.
WEBHOOK_SECRET_CURRENT="change_me_to_a_long_random_secret"

# Optioneel voor zero-downtime secret rotation.
WEBHOOK_SECRET_PREVIOUS=""

# ================= APP =================
NEXT_PUBLIC_APP_NAME="Trade Optimizer"

# ================= LOCAL TESTING =================
WEBHOOK_URL="http://localhost:3000/api/webhooks/tradesystem"

# ================= OPTIONAL =================
NODE_ENV="development"