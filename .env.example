# =========================================================
# APP
# =========================================================

# Vercel zet NODE_ENV automatisch.
# Alleen lokaal handmatig instellen wanneer dat nodig is.
NODE_ENV=production

# Vervang door de echte Production-URL van het Vercel-project.
APP_URL=https://example.vercel.app


# =========================================================
# BEVEILIGING
# =========================================================

# Gebruik voor beide een aparte lange willekeurige waarde.
CRON_SECRET=change-me-long-random
ADMIN_SECRET=change-me-long-random


# =========================================================
# REDIS
# =========================================================

# Vul ÉÉN van de onderstaande twee combinaties in.
#
# Ondersteunde volgorde:
# 1. UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# 2. KV_REST_API_URL / KV_REST_API_TOKEN
#
# Wanneer jouw bestaande Vercel-project al KV_REST_API_URL en
# KV_REST_API_TOKEN bevat, hoef je geen nieuwe Upstash-waarden
# toe te voegen.
#
# Vul bij voorkeur niet beide combinaties in.
# Wanneer beide toch bestaan, gebruikt het systeem eerst UPSTASH_*.


# OPTIE A — nieuwe Upstash-naamgeving

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# OPTIE B — bestaande Vercel KV-naamgeving

KV_REST_API_URL=
KV_REST_API_TOKEN=


# Niet gebruiken:
# KV_REST_API_READ_ONLY_TOKEN=
#
# Het platform schrijft data naar Redis en heeft daarom de normale
# schrijftoken nodig.


# =========================================================
# BITGET
# =========================================================

BITGET_BASE_URL=https://api.bitget.com


# =========================================================
# DISCORD
# =========================================================

DISCORD_SETUPS_WEBHOOK=
DISCORD_VERIFIED_WEBHOOK=
DISCORD_DIGEST_WEBHOOK=
DISCORD_STATUS_WEBHOOK=


# =========================================================
# PLATFORMMODUS
# =========================================================

COLLECTING_MODE=true
PAID_LAUNCH_ENABLED=false
MONTHLY_PRICE_EUR=99


# =========================================================
# BILLING — FASE 9
# =========================================================

# Ondersteund:
# none
# stripe
#
# Alles onder BILLING_PROVIDER is alleen nodig wanneer:
# BILLING_PROVIDER=stripe

BILLING_PROVIDER=none

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_MEMBER_ROLE_ID=


# =========================================================
# SCANNER
# =========================================================

MAX_UNIVERSE_SIZE=150
MIN_DAILY_VOLUME_USD=5000000
MAX_PUBLICATIONS_PER_DAY=12
SCAN_CONCURRENCY=6
SCAN_SHARDS=5


# =========================================================
# INDICATOR EN POSITION ENGINE
# =========================================================

INDICATOR_VERSION=ARS-U-6.1
PARAMETER_VERSION=p1

POSITION_TIMEOUT_MINUTES=2880
COST_R=0.15